# YT Summarizer - Environment Variables
# Copy this file to .env and fill in your values

# ========================
# Backend
# ========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# ========================
# Database
# ========================
DATABASE_PATH=./data/db/yt_summarizer.sqlite

# ========================
# CORS (Frontend URL)
# ========================
CORS_ORIGINS=http://localhost:3000

# ========================
# Processing
# ========================
SUBTITLE_EXTRACTION_TIMEOUT=30
TEXT_FORMATTING_TIMEOUT=10
MAX_RETRIES=3

# ========================
# Phase 2: LLM (future)
# ========================
# LLM_PROVIDER=local
# LLM_MODEL=
# LLM_API_KEY=
