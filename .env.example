# YT Summarizer - Environment Variables
# Copy this file to .env and fill in your values

# ========================
# Backend
# ========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
DEBUG=true

# ========================
# Database
# ========================
DATABASE_PATH=../data/db/yt_summarizer.sqlite

# ========================
# CORS (Frontend URL)
# ========================
CORS_ORIGINS=["http://localhost:3000"]

# ========================
# YouTube cookies (required for subtitle extraction)
# Export from browser using "Get cookies.txt LOCALLY" extension
# ========================
COOKIES_PATH=../data/www.youtube.com_cookies.txt
# yt-dlp path is configured in backend/config.py (ytdlp_path). Override here only if needed.

# ========================
# Processing
# ========================
SUBTITLE_EXTRACTION_TIMEOUT=30
TEXT_FORMATTING_TIMEOUT=10
MAX_RETRIES=3

# ========================
# Ollama (text cleanup + Phase 2 summarization)
# Model is configured in backend/config.py. Override here only if needed.
# ========================
OLLAMA_URL=http://localhost:11434
